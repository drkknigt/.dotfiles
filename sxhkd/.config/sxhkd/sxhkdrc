# Set volume
alt + bracketright
    pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status

alt + bracketleft
    pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status

alt + control + m
    pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status

# Assign extra keys on keyboard for volume control
XF86AudioLowerVolume
    pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status

XF86AudioRaiseVolume
    pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status

XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status

