# Set mode for screen
    
alt + s; {s,1,2,l}
    {alacritty -t "mount" -o "colors.primary.background='#262626'"  -e /home/drkknght/bin/screen/resolution.sh,\
    alacritty -t "mount"  -o "colors.primary.background='#262626'"  -e /home/drkknght/bin/screen/scale.sh 0,\
    alacritty -t "mount"  -o "colors.primary.background='#262626'"  -e /home/drkknght/bin/screen/scale.sh 1,\
    alacritty -t "fzfmenu"  -o "colors.primary.background='#262626'"  -e /home/drkknght/bin/screen/change_background.sh 0,\
    }

alt + s ; r
    alacritty -t "fzfmenu"  -o "colors.primary.background='#262626'"  -e /home/drkknght/bin/screen/change_background.sh 1

alt + {equal,minus}
      {brightnessctl set +3%,brightnessctl set 3%-}


