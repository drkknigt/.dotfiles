# set mode to search stuff

alt + f; {t,a,w,f,d,g}
       {rofi -show run -dpi 171,rofi -dpi 171 -show drun -show-icons,rofi -dpi 171 -show,\
       alacritty -t "fzfmenu-dir"  -o "colors.primary.background='#262626'"  -e /home/drkknght/bin/navigation/file_exp.sh f,\
       alacritty -t "fzfmenu-dir"  -o "colors.primary.background='#262626'"  -e /home/drkknght/bin/navigation/file_exp.sh d, alacritty -t "git"  -o "colors.primary.background='#262626'"  -e /home/drkknght/bin/navigation/lazy_git.sh}

